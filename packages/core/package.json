{
  "name": "@novajs/core",
  "version": "1.0.0",
  "description": "Nova framework — core",
  "keywords": [
    "nova",
    "http",
    "server",
    "framework",
    "typescript",
    "router",
    "middleware",
    "validation",
    "standard-schema"
  ],
  "homepage": "https://github.com/apollobl/nova#readme",
  "bugs": {
    "url": "https://github.com/apollobl/nova/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apollobl/nova.git",
    "directory": "packages/core"
  },
  "author": "Maykeel Santana",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "!dist/.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist .tsbuildinfo"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@novajs/router": "workspace:^",
    "@novajs/validator": "workspace:^"
  }
}
